{
  "manifest_version": 3,
  "name": "FocusForge Guard",
  "version": "1.0.0",
  "description": "Blocks distracting websites during FocusForge study sessions",
  "permissions": ["webNavigation", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "FocusForge"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}